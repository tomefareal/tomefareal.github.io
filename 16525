  <title>Night Bell - Sonnerie Gratuite MP3 | Téléchargement</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --primary: #6aa9ff;
      --primary-light: #8fd3ff;
      --primary-dark: #5b9bff;
      --bg-gradient-start: #f8fbff;
      --bg-gradient-end: #eaf3ff;
      --card-bg: rgba(255, 255, 255, 0.85);
      --card-border: rgba(255, 255, 255, 0.7);
      --text-title: #23415f;
      --text-subtitle: #5b6b7a;
      --text-note: #7a8794;
      --shadow-color: rgba(61, 92, 139, 0.12);
      --shadow-btn: rgba(106, 169, 255, 0.28);
      --shadow-btn-hover: rgba(106, 169, 255, 0.35);
      --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', Arial, sans-serif;
    }

    html {
      font-size: 16px;
      -webkit-text-size-adjust: 100%;
    }

    body {
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));
      color: var(--text-title);
      font-family: var(--font-family);
      padding: clamp(16px, 4vw, 48px);
      line-height: 1.6;
    }

    .card {
      width: 100%;
      max-width: min(90vw, 480px);
      background: var(--card-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: clamp(16px, 4vw, 28px);
      padding: 0 clamp(16px, 4vw, 32px) clamp(24px, 5vw, 40px);
      box-shadow: 0 10px 40px var(--shadow-color);
      text-align: center;
      border: 1px solid var(--card-border);
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 50px var(--shadow-color);
    }

    .banner {
      height: clamp(80px, 15vw, 140px);
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      margin: 0 clamp(-16px, -4vw, -32px) clamp(20px, 4vw, 32px);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: clamp(18px, 4vw, 26px);
      font-weight: 700;
      letter-spacing: 1px;
      box-shadow: inset 0 -1px 0 rgba(255,255,255,0.2);
    }

    .title {
      font-size: clamp(22px, 5vw, 32px);
      margin-bottom: clamp(8px, 2vw, 14px);
      color: var(--text-title);
      font-weight: 700;
      line-height: 1.2;
    }

    .subtitle {
      font-size: clamp(13px, 3vw, 16px);
      color: var(--text-subtitle);
      margin-bottom: clamp(20px, 4vw, 32px);
      line-height: 1.6;
      padding: 0 clamp(4px, 2vw, 16px);
    }

    .audio-wrapper {
      width: 100%;
      margin: clamp(16px, 3vw, 24px) 0;
    }

    audio {
      width: 100%;
      border-radius: 12px;
      height: 44px;
    }

    .download-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: clamp(12px, 3vw, 16px) clamp(24px, 5vw, 36px);
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
      text-decoration: none;
      border-radius: 999px;
      font-size: clamp(14px, 3.5vw, 17px);
      font-weight: 700;
      border: none;
      box-shadow: 0 8px 24px var(--shadow-btn);
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
      min-height: 48px;
      min-width: 200px;
      margin-top: clamp(16px, 3vw, 24px);
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }

    .download-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 32px var(--shadow-btn-hover);
      background: linear-gradient(135deg, var(--primary-dark), #78c9ff);
    }

    .download-btn:active {
      transform: translateY(-1px) scale(0.98);
      transition-duration: 0.1s;
    }

    .note {
      margin-top: clamp(14px, 3vw, 20px);
      font-size: clamp(11px, 2.5vw, 13px);
      color: var(--text-note);
      word-break: break-all;
    }

    /* Petits écrans mobiles (jusqu'à 380px) */
    @media (max-width: 380px) {
      .card {
        border-radius: 16px;
        padding: 0 14px 24px;
      }

      .banner {
        margin: 0 -14px 16px;
        height: 70px;
      }

      audio {
        height: 40px;
      }

      .download-btn {
        width: 100%;
        min-width: unset;
      }
    }

    /* Mobile standard (381px - 480px) */
    @media (min-width: 381px) and (max-width: 480px) {
      .card {
        max-width: 100%;
      }
    }

    /* Tablettes (481px - 768px) */
    @media (min-width: 481px) and (max-width: 768px) {
      .card {
        max-width: 420px;
      }
    }

    /* PC et grands écrans (769px+) */
    @media (min-width: 769px) {
      .card {
        max-width: 460px;
        padding: 0 36px 40px;
      }

      .banner {
        margin: 0 -36px 32px;
      }
    }

    /* Très grands écrans (1200px+) */
    @media (min-width: 1200px) {
      .card {
        max-width: 480px;
      }
    }

    /* Mode paysage sur mobile */
    @media (max-height: 500px) and (orientation: landscape) {
      body {
        padding: 12px;
        align-items: flex-start;
      }

      .card {
        padding: 0 20px 20px;
      }

      .banner {
        height: 60px;
        margin-bottom: 16px;
      }

      .title {
        font-size: 20px;
        margin-bottom: 6px;
      }

      .subtitle {
        font-size: 12px;
        margin-bottom: 12px;
      }

      audio {
        margin: 8px 0;
      }

      .download-btn {
        margin-top: 12px;
        padding: 10px 24px;
        min-height: 40px;
      }
    }

    /* Réduction des animations si demandé */
    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* Support des écrans à haute densité */
    @media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
      .card {
        border-width: 0.5px;
      }
    }

    /* Curseur adaptatif selon le type de pointage */
    @media (hover: none) and (pointer: coarse) {
      .download-btn:active {
        transform: scale(0.97);
      }

      .card:hover {
        transform: none;
      }
    }
  </style>
<base target="_blank">
